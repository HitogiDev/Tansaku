    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storageKey = "tansaku-theme";
        const toggleButton = document.getElementById("theme-toggle");
        const toggleLabel = document.getElementById("theme-toggle-label");
        const iconSun = document.getElementById("theme-icon-sun");
        const iconMoon = document.getElementById("theme-icon-moon");

        const updateLabel = (theme) => {
          if (!toggleLabel) return;
          toggleLabel.textContent =
            theme === "dark" ? "Modo claro" : "Modo oscuro";

          if (iconSun) iconSun.hidden = theme === "dark";
          if (iconMoon) iconMoon.hidden = theme !== "dark";
        };

        const applyTheme = (theme, persist) => {
          root.setAttribute("data-theme", theme);
          toggleButton?.setAttribute(
            "aria-pressed",
            theme === "dark" ? "true" : "false",
          );
          updateLabel(theme);

          if (!persist) return;
          try {
            window.localStorage.setItem(storageKey, theme);
          } catch {
            // Ignore storage errors so toggling still works.
          }
        };

        let savedTheme = null;
        try {
          savedTheme = window.localStorage.getItem(storageKey);
        } catch {
          savedTheme = null;
        }

        const initialTheme =
          savedTheme === "dark" || savedTheme === "light" ? savedTheme : "dark";

        applyTheme(initialTheme, false);

        toggleButton?.addEventListener("click", () => {
          const currentTheme =
            root.getAttribute("data-theme") === "dark" ? "dark" : "light";
          applyTheme(currentTheme === "dark" ? "light" : "dark", true);
        });

        const previewGrid = document.getElementById("catalog-preview-grid");
        if (previewGrid) {
          const cards = Array.from(
            previewGrid.querySelectorAll("[data-catalog-item]"),
          );
          const visibleCount = Math.min(6, cards.length);

          for (let i = cards.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [cards[i], cards[j]] = [cards[j], cards[i]];
          }

          const selectedCards = cards.slice(0, visibleCount);
          const selectedSet = new Set(selectedCards);

          cards.forEach((card) => {
            card.classList.toggle("is-active", selectedSet.has(card));
          });

          selectedCards.forEach((card) => {
            previewGrid.appendChild(card);
          });
        }
      })();
    </script>
  </body>
