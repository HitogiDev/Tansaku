---
import { Image } from 'astro:assets';
import '../styles/global.css';

const currentYear = new Date().getFullYear();

function shuffleArray<T>(array: T[]) {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
}

const coverModules = import.meta.glob(
  '../assets/covers/*.{jpg,jpeg,png,webp,avif}',
  {
    eager: true,
    import: 'default',
  },
) as Record<string, import('astro').ImageMetadata>;

const covers = shuffleArray(Object.values(coverModules));
const minItemsPerRow = Math.max(covers.length, 16);

const mangaMetaBySlug: Record<string, { title: string; genre: string }> = {
  akane: { title: 'Akane Banashi', genre: 'Drama / Shonen' },
  aonohako: { title: 'Ao no Hako', genre: 'Romance / Shonen' },
  csm: { title: 'Chainsaw Man', genre: 'Acción / Shonen' },
  dandadan: { title: 'Dandadan', genre: 'Acción / Seinen' },
  jujutsu: { title: 'Jujutsu Kaisen', genre: 'Acción / Shonen' },
  kagurabachi: { title: 'Kagurabachi', genre: 'Acción / Shonen' },
  madannoichi: { title: 'Madan no Ichi', genre: 'Fantasía / Shonen' },
  mushoku: { title: 'Mushoku Tensei', genre: 'Fantasía / Seinen' },
  onepiece: { title: 'One Piece', genre: 'Aventura / Shonen' },
  sakamoto: { title: 'Sakamoto Days', genre: 'Acción / Shonen' },
  spyfamily: { title: 'Spy x Family', genre: 'Comedia / Shonen' },
  witchwatch: { title: 'Witch Watch', genre: 'Comedia / Drama' },
  opm: { title: 'One Punch Man', genre: 'Acción / Comedia' },
  punpun: { title: 'Oyasumi Punpun', genre: 'Drama / Psicológico' },
  tokyoghoul: { title: 'Tokyo Ghoul', genre: 'Acción / Horror' },
  hxh: { title: 'Hunter x Hunter', genre: 'Acción / Aventura' },
  deathnote: { title: 'Death Note', genre: 'Drama / Misterio' },
  '100kano': {
    title: 'Kimi no Koto ga Dai Dai Dai Dai Daisuki na 100-nin no Kanojo',
    genre: 'Romance / Comedia',
  },
};

const catalogItems = Object.entries(coverModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, image], index) => {
    const fileName = path.split('/').pop() ?? '';
    const slug = fileName.split('.')[0]?.toLowerCase() ?? '';
    const meta = mangaMetaBySlug[slug] ?? {
      title: slug
        .replace(/[-_]/g, ' ')
        .replace(/\b\w/g, (char) => char.toUpperCase()),
      genre: 'Manga / Interés',
    };

    return {
      index: String(index + 1).padStart(2, '0'),
      title: meta.title,
      genre: meta.genre,
      image,
    };
  });

const heroRows = Array.from({ length: 4 }, (_, rowIndex) =>
  Array.from(
    { length: minItemsPerRow },
    (_, imageIndex) => covers[(rowIndex * 3 + imageIndex) % covers.length],
  ),
);
---

